<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>TurtleAIQuartetHub</AssemblyName>
    <RootNamespace>TurtleAIQuartetHub.Panel</RootNamespace>
    <AssemblyTitle>Turtle AI Code Quartet Hub</AssemblyTitle>
    <Product>Turtle AI Code Quartet Hub</Product>
    <FileDescription>Turtle AI Code Quartet Hub</FileDescription>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="app.ico" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\config\turtle-ai-quartet-hub.example.json" Link="config\turtle-ai-quartet-hub.example.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\LICENSE.txt" Link="LICENSE.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
