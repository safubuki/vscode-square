<Window x:Class="TurtleAIQuartetHub.Panel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TurtleAIQuartetHub.Panel.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Turtle AI Quartet Hub"
        Width="600"
        Height="376"
        MinWidth="524"
        MinHeight="336"
        Background="#101211"
        Foreground="#EEF4EF"
        FontFamily="Segoe UI"
        FontSize="12"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Icon="app.ico"
        PreviewMouseDown="Window_PreviewMouseDown">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="34"
                        ResizeBorderThickness="8"
                        GlassFrameThickness="0"
                        CornerRadius="0"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#101211" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#171B19" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1D2420" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#2E3832" />
    <SolidColorBrush x:Key="TextBrush" Color="#EEF4EF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA59E" />
    <SolidColorBrush x:Key="AccentBrush" Color="#45D483" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#123222" />
    <SineEase x:Key="LedEase" EasingMode="EaseInOut" />

    <Style TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="InlineTitleTextBox" TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="2,1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="EditorBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="EditorBorder" Property="Background" Value="#202823" />
                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#4C6B59" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#3A453E" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="IsReadOnly" Value="True" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Cursor" Value="Arrow" />
      <EventSetter Event="PreviewKeyDown" Handler="InlineTitleTextBox_PreviewKeyDown" />
      <EventSetter Event="PreviewMouseLeftButtonDown" Handler="InlineTitleTextBox_PreviewMouseLeftButtonDown" />
      <EventSetter Event="LostKeyboardFocus" Handler="InlineTitleTextBox_LostKeyboardFocus" />
    </Style>

    <Style x:Key="BaseButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="#202823" />
      <Setter Property="BorderBrush" Value="#3A453E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="11,6" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#2B352F" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#53645A" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#18201B" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="LaunchButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="Foreground" Value="#06120C" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,5" />
    </Style>

    <Style x:Key="MiniButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="MinWidth" Value="54" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Background" Value="#17201B" />
      <Setter Property="BorderBrush" Value="#385345" />
    </Style>

    <Style x:Key="BarButton" TargetType="Button" BasedOn="{StaticResource MiniButton}">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="6,3" />
      <Setter Property="Background" Value="#1B221E" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="CompactBarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource BarButton}">
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SlotActionButton" TargetType="Button" BasedOn="{StaticResource MiniButton}">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="MinWidth" Value="58" />
    </Style>

    <Style x:Key="StoredAssignButton" TargetType="Button" BasedOn="{StaticResource MiniButton}">
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="StoredDeleteButton" TargetType="Button" BasedOn="{StaticResource StoredAssignButton}">
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="#F2B7AF" />
      <Setter Property="Background" Value="#261816" />
      <Setter Property="BorderBrush" Value="#6A3832" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="ToolTip" Value="この控えを削除" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding HasContent}" Value="False">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="Foreground" Value="#FFF4F2" />
      <Setter Property="Background" Value="#6F2D27" />
      <Setter Property="BorderBrush" Value="#B3574E" />
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style x:Key="ChromeButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#25302A" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TinyPill" TargetType="Border">
      <Setter Property="Background" Value="#242B27" />
      <Setter Property="BorderBrush" Value="#3A463F" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="MinHeight" Value="24" />
    </Style>

    <Style x:Key="StatusPillTextStyle" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
      <Setter Property="LineHeight" Value="15" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style x:Key="AiPillTextStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusPillTextStyle}">
      <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Running}">
          <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Completed}">
          <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.WaitingForConfirmation}">
          <Setter Property="Foreground" Value="#F5D66B" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="WindowPillTextStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusPillTextStyle}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsHidden}" Value="True">
          <Setter Property="Foreground" Value="#D4C47A" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="WindowPill" TargetType="Border" BasedOn="{StaticResource TinyPill}">
      <Setter Property="MinWidth" Value="52" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Ready}">
          <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
          <Setter Property="BorderBrush" Value="#287B4A" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Background" Value="#302817" />
          <Setter Property="BorderBrush" Value="#7B6129" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Background" Value="#311B1A" />
          <Setter Property="BorderBrush" Value="#79403A" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsHidden}" Value="True">
          <Setter Property="Background" Value="#28251A" />
          <Setter Property="BorderBrush" Value="#8B7D3E" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="AiPill" TargetType="Border" BasedOn="{StaticResource TinyPill}">
      <Style.Triggers>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Running}">
          <Setter Property="Background" Value="#123222" />
          <Setter Property="BorderBrush" Value="#287B4A" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#45D483"
                                BlurRadius="9"
                                ShadowDepth="0"
                                Opacity="0.42" />
            </Setter.Value>
          </Setter>
          <DataTrigger.EnterActions>
            <BeginStoryboard Name="AiRunningPulse">
              <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#17482F"
                                Duration="0:0:0.68"
                                EasingFunction="{StaticResource LedEase}" />
                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                To="#45D483"
                                Duration="0:0:0.68"
                                EasingFunction="{StaticResource LedEase}" />
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 To="0.84"
                                 Duration="0:0:0.68"
                                 EasingFunction="{StaticResource LedEase}" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <RemoveStoryboard BeginStoryboardName="AiRunningPulse" />
          </DataTrigger.ExitActions>
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Completed}">
          <Setter Property="Background" Value="#123044" />
          <Setter Property="BorderBrush" Value="#2DA8E8" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#2DA8E8"
                                BlurRadius="10"
                                ShadowDepth="0"
                                Opacity="0.36" />
            </Setter.Value>
          </Setter>
          <DataTrigger.EnterActions>
            <BeginStoryboard Name="AiCompletedPulse">
              <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#19536D"
                                Duration="0:0:2.1"
                                EasingFunction="{StaticResource LedEase}" />
                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                To="#5BD0FF"
                                Duration="0:0:2.1"
                                EasingFunction="{StaticResource LedEase}" />
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 To="0.9"
                                 Duration="0:0:2.1"
                                 EasingFunction="{StaticResource LedEase}" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <RemoveStoryboard BeginStoryboardName="AiCompletedPulse" />
          </DataTrigger.ExitActions>
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Error}">
          <Setter Property="Background" Value="#311B1A" />
          <Setter Property="BorderBrush" Value="#79403A" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.NeedsAttention}">
          <Setter Property="Background" Value="#302817" />
          <Setter Property="BorderBrush" Value="#7B6129" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.WaitingForConfirmation}">
          <Setter Property="Background" Value="#2E2813" />
          <Setter Property="BorderBrush" Value="#C49B38" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#E8B830"
                                BlurRadius="9"
                                ShadowDepth="0"
                                Opacity="0.38" />
            </Setter.Value>
          </Setter>
          <DataTrigger.EnterActions>
            <BeginStoryboard Name="AiConfirmPulse">
              <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#3D3418"
                                Duration="0:0:1.4"
                                EasingFunction="{StaticResource LedEase}" />
                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                To="#E8C84A"
                                Duration="0:0:1.4"
                                EasingFunction="{StaticResource LedEase}" />
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 To="0.88"
                                 Duration="0:0:1.4"
                                 EasingFunction="{StaticResource LedEase}" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <RemoveStoryboard BeginStoryboardName="AiConfirmPulse" />
          </DataTrigger.ExitActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SlotCardBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Cursor" Value="Hand" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#1A211D" />
          <Setter Property="BorderBrush" Value="#3D4E45" />
        </Trigger>
        <DataTrigger Binding="{Binding IsFocused}" Value="True">
          <Setter Property="Background" Value="#18231D" />
          <Setter Property="BorderBrush" Value="#45D483" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#45D483"
                                BlurRadius="11"
                                ShadowDepth="0"
                                Opacity="0.3" />
            </Setter.Value>
          </Setter>
          <DataTrigger.EnterActions>
            <BeginStoryboard Name="FocusedCardPulse">
              <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                To="#1C3327"
                                Duration="0:0:1.65"
                                EasingFunction="{StaticResource LedEase}" />
                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                To="#7EF3AF"
                                Duration="0:0:1.65"
                                EasingFunction="{StaticResource LedEase}" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <RemoveStoryboard BeginStoryboardName="FocusedCardPulse" />
          </DataTrigger.ExitActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CompactSlotButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="MinWidth" Value="44" />
      <Setter Property="Padding" Value="5,2" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="CompactButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CompactButtonBorder" Property="Background" Value="#1A211D" />
                <Setter TargetName="CompactButtonBorder" Property="BorderBrush" Value="#3D4E45" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="CompactButtonBorder" Property="Background" Value="#121715" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
          <Setter Property="BorderBrush" Value="#505B55" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Background" Value="#241F15" />
          <Setter Property="BorderBrush" Value="#A27E39" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Running}">
          <Setter Property="Background" Value="#18231D" />
          <Setter Property="BorderBrush" Value="#45D483" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#45D483"
                                BlurRadius="6"
                                ShadowDepth="0"
                                Opacity="0.22" />
            </Setter.Value>
          </Setter>
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Completed}">
          <Setter Property="Background" Value="#172534" />
          <Setter Property="BorderBrush" Value="#43C8FF" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#43C8FF"
                                BlurRadius="6"
                                ShadowDepth="0"
                                Opacity="0.2" />
            </Setter.Value>
          </Setter>
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.WaitingForConfirmation}">
          <Setter Property="Background" Value="#272113" />
          <Setter Property="BorderBrush" Value="#F2CA57" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#F2CA57"
                                BlurRadius="6"
                                ShadowDepth="0"
                                Opacity="0.2" />
            </Setter.Value>
          </Setter>
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.NeedsAttention}">
          <Setter Property="Background" Value="#242014" />
          <Setter Property="BorderBrush" Value="#C9A441" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Error}">
          <Setter Property="Background" Value="#261918" />
          <Setter Property="BorderBrush" Value="#E37B70" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsFocused}" Value="True">
          <Setter Property="BorderThickness" Value="2" />
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#9BF6C1"
                                BlurRadius="8"
                                ShadowDepth="0"
                                Opacity="0.24" />
            </Setter.Value>
          </Setter>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CompactStatusDotStyle" TargetType="Ellipse">
      <Setter Property="Width" Value="5" />
      <Setter Property="Height" Value="5" />
      <Setter Property="Fill" Value="#54675C" />
      <Setter Property="Stroke" Value="#73847B" />
      <Setter Property="StrokeThickness" Value="0.8" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Fill" Value="#666F6A" />
          <Setter Property="Stroke" Value="#87928B" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Fill" Value="#C9A441" />
          <Setter Property="Stroke" Value="#F2CA57" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Running}">
          <Setter Property="Fill" Value="#45D483" />
          <Setter Property="Stroke" Value="#BDF9D4" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Completed}">
          <Setter Property="Fill" Value="#43C8FF" />
          <Setter Property="Stroke" Value="#C9F2FF" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.WaitingForConfirmation}">
          <Setter Property="Fill" Value="#F2CA57" />
          <Setter Property="Stroke" Value="#FFF0B5" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.NeedsAttention}">
          <Setter Property="Fill" Value="#C9A441" />
          <Setter Property="Stroke" Value="#F2DD95" />
        </DataTrigger>
        <DataTrigger Binding="{Binding AiStatus}" Value="{x:Static models:AiStatus.Error}">
          <Setter Property="Fill" Value="#E37B70" />
          <Setter Property="Stroke" Value="#FFD2CE" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="StoredCardBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="6" />
    </Style>

    <Style x:Key="StoredPanelsExpanderStyle" TargetType="Expander">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="LedIndicatorStyle" TargetType="Ellipse">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="Fill" Value="#3A4941" />
      <Setter Property="Stroke" Value="#54675C" />
      <Setter Property="StrokeThickness" Value="1" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsTopmostLayer}" Value="True">
          <Setter Property="Fill" Value="#2E9C5E" />
          <Setter Property="Stroke" Value="#7EF3AF" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsBackmostLayer}" Value="True">
          <Setter Property="Fill" Value="#59655E" />
          <Setter Property="Stroke" Value="#7C8A82" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsFocused}" Value="True">
          <Setter Property="Fill" Value="#7AF7B2" />
          <Setter Property="Stroke" Value="#D7FFE8" />
          <DataTrigger.EnterActions>
            <BeginStoryboard Name="FocusedLedPulse">
              <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                <ColorAnimation Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                To="#45D483"
                                Duration="0:0:1.45"
                                EasingFunction="{StaticResource LedEase}" />
                <ColorAnimation Storyboard.TargetProperty="(Ellipse.Stroke).(SolidColorBrush.Color)"
                                To="#FFFFFF"
                                Duration="0:0:1.45"
                                EasingFunction="{StaticResource LedEase}" />
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 To="0.78"
                                 Duration="0:0:1.45"
                                 EasingFunction="{StaticResource LedEase}" />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <RemoveStoryboard BeginStoryboardName="FocusedLedPulse" />
          </DataTrigger.ExitActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="SlotCardTemplate" DataType="{x:Type models:WindowSlot}">
      <Border Style="{StaticResource SlotCardBorderStyle}"
              Tag="{Binding}"
              MouseLeftButtonUp="SlotCard_MouseLeftButtonUp"
              PreviewMouseLeftButtonDown="SlotCard_PreviewMouseLeftButtonDown"
              PreviewMouseMove="SlotCard_PreviewMouseMove"
              AllowDrop="True"
              DragEnter="SlotCard_DragEnter"
              DragLeave="SlotCard_DragLeave"
              DragOver="SlotCard_DragOver"
              Drop="SlotCard_Drop">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Width="28"
                    Height="28"
                    CornerRadius="8"
                    Background="#223027"
                    BorderBrush="#335A43"
                    BorderThickness="1"
                    Margin="0,0,8,0">
              <TextBlock Text="{Binding Name}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}" />
            </Border>
            <Ellipse Grid.Column="1" Style="{StaticResource LedIndicatorStyle}" VerticalAlignment="Center" />
            <StackPanel Grid.Column="2">
              <TextBox Text="{Binding PanelTitle, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="ダブルクリックで名前を編集"
                       Style="{StaticResource InlineTitleTextBox}"
                       MaxLength="40" />
              <TextBlock Text="{Binding ShortPath}"
                         Margin="0,2,0,0"
                         Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
          </Grid>

          <Grid Grid.Row="1"
                Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <WrapPanel Grid.Column="0"
                       VerticalAlignment="Center">
              <Border Style="{StaticResource WindowPill}" Margin="0,0,6,0">
                <TextBlock Text="{Binding WindowStatusText}" Style="{StaticResource WindowPillTextStyle}" />
              </Border>
              <Border Style="{StaticResource AiPill}" Margin="0,0,6,0" ToolTip="{Binding AiStatusDetail}">
                <TextBlock Text="{Binding AiStatusText}" Style="{StaticResource AiPillTextStyle}" />
              </Border>
            </WrapPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
              <Button Tag="{Binding}"
                      Click="StoreSlotButton_Click"
                      Margin="8,0,6,0">
                <Button.Style>
                  <Style TargetType="Button" BasedOn="{StaticResource SlotActionButton}">
                    <Setter Property="Content" Value="控えへ" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding HasPanelContent}" Value="False">
                        <Setter Property="IsEnabled" Value="False" />
                        <Setter Property="Opacity" Value="0.4" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Button.Style>
              </Button>
              <Button Tag="{Binding}"
                      Click="SlotMainActionButton_Click"
                      MinWidth="58">
                <Button.Style>
                  <Style TargetType="Button" BasedOn="{StaticResource SlotActionButton}">
                    <Setter Property="Content" Value="停止" />
                    <Style.Triggers>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}" />
                          <Condition Binding="{Binding HasPanelContent}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Content" Value="起動" />
                      </MultiDataTrigger>
                      <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                          <Condition Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}" />
                          <Condition Binding="{Binding HasPanelContent}" Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Content" Value="新規" />
                      </MultiDataTrigger>
                      <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
                        <Setter Property="Content" Value="起動中" />
                        <Setter Property="IsEnabled" Value="False" />
                        <Setter Property="Opacity" Value="0.5" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Button.Style>
              </Button>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="CompactSlotTemplate" DataType="{x:Type models:WindowSlot}">
      <Button Tag="{Binding}"
              Click="CompactSlotButton_Click"
              Style="{StaticResource CompactSlotButtonStyle}"
              ToolTip="{Binding AiStatusDetail}">
        <Grid VerticalAlignment="Center">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Border Width="16"
                  Height="16"
                  CornerRadius="4"
                  Background="#223027"
                  BorderBrush="#335A43"
                  BorderThickness="1"
                  Margin="0,0,4,0"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding Name}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}" />
          </Border>

          <TextBlock Grid.Column="1"
                     Text="{Binding DisplayTitle}"
                     ToolTip="{Binding DisplayTitle}"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis"
                     Foreground="{StaticResource TextBrush}" />

          <Ellipse Grid.Column="2"
                   Margin="4,0,0,0"
                   VerticalAlignment="Center"
                   Style="{StaticResource CompactStatusDotStyle}" />
        </Grid>
      </Button>
    </DataTemplate>

    <DataTemplate x:Key="StoredPanelTemplate" DataType="{x:Type models:StoredPanelSlot}">
      <Border Style="{StaticResource StoredCardBorderStyle}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="28"
                    Height="20"
                    CornerRadius="6"
                    Background="#223027"
                    BorderBrush="#335A43"
                    BorderThickness="1"
                    Margin="0,0,8,0">
              <TextBlock Text="{Binding Label}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}" />
            </Border>

            <TextBlock Grid.Column="1"
                       Text="{Binding DisplayTitle}"
                       ToolTip="{Binding DisplayTitle}"
                       Margin="0,0,6,0"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

                <Button Grid.Column="2"
                  Content="&#xE74D;"
                  Tag="{Binding}"
                  Click="DeleteStoredPanelButton_Click"
                  Style="{StaticResource StoredDeleteButton}"
                  VerticalAlignment="Top"
                  IsEnabled="{Binding HasContent}" />
          </Grid>

          <TextBlock Grid.Row="1"
                     Text="{Binding ShortPath}"
                     Margin="0,4,0,0"
                     Foreground="{StaticResource MutedTextBrush}"
                     FontSize="10" />

              <Grid Grid.Row="2" Margin="0,8,0,0" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                  Grid.Column="0"
                    Content="A"
                    Tag="{Binding}"
                    CommandParameter="A"
                    Click="ShowStoredPanelButton_Click"
                    Style="{StaticResource StoredAssignButton}"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,4,4"
                    IsEnabled="{Binding HasContent}" />
                <Button Grid.Row="0"
                  Grid.Column="1"
                    Content="B"
                    Tag="{Binding}"
                    CommandParameter="B"
                    Click="ShowStoredPanelButton_Click"
                    Style="{StaticResource StoredAssignButton}"
                  HorizontalAlignment="Stretch"
                  Margin="4,0,0,4"
                    IsEnabled="{Binding HasContent}" />
                <Button Grid.Row="1"
                  Grid.Column="0"
                    Content="C"
                    Tag="{Binding}"
                    CommandParameter="C"
                    Click="ShowStoredPanelButton_Click"
                    Style="{StaticResource StoredAssignButton}"
                  HorizontalAlignment="Stretch"
                  Margin="0,4,4,0"
                    IsEnabled="{Binding HasContent}" />
                <Button Grid.Row="1"
                  Grid.Column="1"
                    Content="D"
                    Tag="{Binding}"
                    CommandParameter="D"
                    Click="ShowStoredPanelButton_Click"
                    Style="{StaticResource StoredAssignButton}"
                  HorizontalAlignment="Stretch"
                  Margin="4,4,0,0"
                    IsEnabled="{Binding HasContent}" />
          </Grid>
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <Border x:Name="PanelFrameBorder"
          Background="Transparent"
          BorderBrush="Transparent"
          BorderThickness="0"
          CornerRadius="0">
  <Grid x:Name="RootLayoutGrid" Background="{StaticResource PanelBackgroundBrush}" Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="26" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <TextBlock Text="Turtle AI Quartet Hub"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextBrush}" />
      <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
        <Button x:Name="DisplayModeButton"
                Content="&#xE73F;"
                Width="30"
                FontFamily="Segoe MDL2 Assets"
                FontSize="12"
                FontWeight="SemiBold"
                ToolTip="縮小表示へ切り替え"
                Click="DisplayModeButton_Click"
                Style="{StaticResource ChromeButton}" />
        <Button Content="_"
                ToolTip="最小化"
                Click="MinimizeButton_Click"
                Style="{StaticResource ChromeButton}"
                Margin="2,0,0,0" />
        <Button Content="X"
                ToolTip="パネルを閉じる"
                Click="CloseButton_Click"
                Style="{StaticResource ChromeButton}"
                Margin="2,0,0,0" />
      </StackPanel>
    </Grid>

    <UniformGrid x:Name="StandardSlotsGrid" Grid.Row="1" Columns="2" Rows="2" VerticalAlignment="Top">
      <ContentControl
                      Content="{Binding Slots[0]}"
                      ContentTemplate="{StaticResource SlotCardTemplate}"
                      Margin="5" />
      <ContentControl
                      Content="{Binding Slots[1]}"
                      ContentTemplate="{StaticResource SlotCardTemplate}"
                      Margin="5" />
      <ContentControl
                      Content="{Binding Slots[2]}"
                      ContentTemplate="{StaticResource SlotCardTemplate}"
                      Margin="5" />
      <ContentControl
                      Content="{Binding Slots[3]}"
                      ContentTemplate="{StaticResource SlotCardTemplate}"
                      Margin="5" />
    </UniformGrid>

    <Border x:Name="CompactBarPanel"
            Grid.Row="1"
            Visibility="Collapsed"
            Margin="5,3,5,0"
            Padding="3"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0"
                        Grid.Column="0"
                        Content="{Binding Slots[0]}"
                        ContentTemplate="{StaticResource CompactSlotTemplate}"
                        Margin="0,0,3,3" />
        <ContentControl Grid.Row="0"
                        Grid.Column="1"
                        Content="{Binding Slots[1]}"
                        ContentTemplate="{StaticResource CompactSlotTemplate}"
                        Margin="0,0,3,3" />
        <ContentControl Grid.Row="1"
                        Grid.Column="0"
                        Content="{Binding Slots[2]}"
                        ContentTemplate="{StaticResource CompactSlotTemplate}"
                        Margin="0,0,3,0" />
        <ContentControl Grid.Row="1"
                        Grid.Column="1"
                        Content="{Binding Slots[3]}"
                        ContentTemplate="{StaticResource CompactSlotTemplate}"
                        Margin="0,0,3,0" />

        <Button Grid.Row="0"
                Grid.Column="2"
                Content="前"
                Click="PinAllTopButton_Click"
                Style="{StaticResource CompactBarActionButtonStyle}"
                Margin="0,0,0,3" />
        <Button Grid.Row="1"
                Grid.Column="2"
                Content="背"
                Click="SendAllBackButton_Click"
                Style="{StaticResource CompactBarActionButtonStyle}" />
      </Grid>
    </Border>

    <Expander Grid.Row="2"
          x:Name="StoredPanelsExpander"
              Style="{StaticResource StoredPanelsExpanderStyle}"
              IsExpanded="False"
          Expanded="StoredPanelsExpander_Expanded"
          Collapsed="StoredPanelsExpander_Collapsed"
              Margin="5,2,5,3">
      <Expander.Header>
        <TextBlock Text="控え Quartet"
                   Foreground="{StaticResource MutedTextBrush}"
                   FontSize="10" />
      </Expander.Header>
            <Border x:Name="StoredPanelsExpanderContent"
              Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrushSoft}"
              BorderThickness="1"
              CornerRadius="8"
              Margin="0,6,0,0"
              Padding="6">
        <UniformGrid Columns="4">
          <ContentControl Content="{Binding StoredPanels[0]}"
                          ContentTemplate="{StaticResource StoredPanelTemplate}"
                          Margin="0,0,4,0" />
          <ContentControl Content="{Binding StoredPanels[1]}"
                          ContentTemplate="{StaticResource StoredPanelTemplate}"
                          Margin="0,0,4,0" />
          <ContentControl Content="{Binding StoredPanels[2]}"
                          ContentTemplate="{StaticResource StoredPanelTemplate}"
                          Margin="0,0,4,0" />
          <ContentControl Content="{Binding StoredPanels[3]}"
                          ContentTemplate="{StaticResource StoredPanelTemplate}" />
        </UniformGrid>
      </Border>
    </Expander>

    <Grid x:Name="FooterControlsGrid" Grid.Row="3" Margin="5,2,5,3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrushSoft}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="7,4"
                Margin="0,0,5,0">
        <TextBlock Text="{Binding Message}"
                   Foreground="{StaticResource MutedTextBrush}"
                   FontSize="10"
                   TextWrapping="Wrap" />
      </Border>

      <StackPanel Grid.Column="1"
                  VerticalAlignment="Center"
                  Width="290">
        <Grid Margin="0,0,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="3*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
            x:Name="ToggleMonitorButton"
            Content="ディスプレイ移動"
            Click="ToggleMonitorButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="1"
            x:Name="TopmostAllButton"
            Content="最前面"
            Click="PinAllTopButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="2"
            x:Name="BackmostAllButton"
            Content="最背面"
            Click="SendAllBackButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="3"
            x:Name="ToggleVisibilityButton"
            Content="非表示"
            Click="ToggleVisibilityButton_Click"
                  Style="{StaticResource BarButton}" />
        </Grid>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="9*" />
            <ColumnDefinition Width="9*" />
            <ColumnDefinition Width="10*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
                  x:Name="SaveSettingsButton"
                  Content="設定保存"
                  Click="SaveSettingsButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="1"
                  x:Name="LoadSettingsButton"
                  Content="設定読み込み"
                  Click="LoadSettingsButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="2"
                  x:Name="CloseAllButton"
                  Content="全て閉じる"
                  Click="CloseAllButton_Click"
                  Style="{StaticResource BarButton}" />
        </Grid>
      </StackPanel>
    </Grid>

        <Button Grid.Row="4"
          x:Name="LaunchButton"
            Click="LaunchButton_Click"
            Style="{StaticResource LaunchButtonStyle}"
            HorizontalAlignment="Stretch"
            Margin="5,5,5,0">
          <TextBlock>
            <Run Text="Launch Quartet" /><Run Text=" （一括起動）" FontSize="11" BaselineAlignment="Center" />
          </TextBlock>
        </Button>

    <Border x:Name="DeleteStoredPanelOverlay"
            Grid.RowSpan="5"
            Visibility="Collapsed"
            Background="#96090B0A"
            Panel.ZIndex="20">
      <Grid>
        <Border Width="372"
                MaxWidth="420"
                Padding="16"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="#6A3832"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Width="34"
                      Height="34"
                      CornerRadius="10"
                      Background="#2B1715"
                      BorderBrush="#6A3832"
                      BorderThickness="1"
                      Margin="0,0,12,0">
                <TextBlock Text="&#xE74D;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="#F2B7AF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>

              <StackPanel Grid.Column="1">
                <TextBlock Text="控えを削除しますか？"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock x:Name="DeleteStoredPanelMessageText"
                           Margin="0,5,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedTextBrush}" />
              </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,14,0,0"
                    Padding="10,8"
                    Background="#1D2420"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel>
                <TextBlock x:Name="DeleteStoredPanelDetailText"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock x:Name="DeleteStoredPanelPathText"
                           Margin="0,4,0,0"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="10"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <TextBlock Grid.Row="2"
                       Margin="0,12,0,0"
                       Text="削除すると、この控えスロットは空きになります。"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="3"
                        Margin="0,16,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
              <Button x:Name="CancelDeleteStoredPanelButton"
                      Content="キャンセル"
                      Click="CancelDeleteStoredPanelButton_Click"
                      Style="{StaticResource BaseButton}"
                      MinWidth="96"
                      Margin="0,0,8,0" />
              <Button x:Name="ConfirmDeleteStoredPanelButton"
                      Content="削除する"
                      Click="ConfirmDeleteStoredPanelButton_Click"
                      Style="{StaticResource DangerButtonStyle}" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
  </Border>
</Window>
