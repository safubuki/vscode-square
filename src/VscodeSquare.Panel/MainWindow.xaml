<Window x:Class="VscodeSquare.Panel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:VscodeSquare.Panel.Models"
        Title="VS Code Square"
        Width="760"
        Height="360"
        MinWidth="680"
        MinHeight="320"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Margin" Value="0,0,8,0" />
    </Style>
    <Style TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Window.Resources>

  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
      <Button x:Name="LaunchButton" Content="Launch 4" Click="LaunchButton_Click" />
      <Button x:Name="ArrangeButton" Content="Arrange" Click="ArrangeButton_Click" />
      <Button x:Name="FocusAllButton" Content="Focus All" Click="FocusAllButton_Click" />
      <Button Content="Refresh" Click="RefreshButton_Click" />
    </StackPanel>

    <Border DockPanel.Dock="Bottom" BorderBrush="#DDDDDD" BorderThickness="1,0,0,0" Padding="0,10,0,0" Margin="0,12,0,0">
      <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
    </Border>

    <ListView ItemsSource="{Binding Slots}" HorizontalContentAlignment="Stretch">
      <ListView.View>
        <GridView>
          <GridViewColumn Header="Slot" Width="56" DisplayMemberBinding="{Binding Name}" />
          <GridViewColumn Header="Path" Width="210" DisplayMemberBinding="{Binding Path}" />
          <GridViewColumn Header="Window" Width="90" DisplayMemberBinding="{Binding WindowStatus}" />
          <GridViewColumn Header="AI" Width="115" DisplayMemberBinding="{Binding AiStatus}" />
          <GridViewColumn Header="Last Event" Width="105" DisplayMemberBinding="{Binding LastEventText}" />
          <GridViewColumn Header="Title" Width="230" DisplayMemberBinding="{Binding WindowTitle}" />
          <GridViewColumn Header="Action" Width="80">
            <GridViewColumn.CellTemplate>
              <DataTemplate DataType="{x:Type models:WindowSlot}">
                <Button Content="Focus" Tag="{Binding}" Click="FocusSlotButton_Click" />
              </DataTemplate>
            </GridViewColumn.CellTemplate>
          </GridViewColumn>
        </GridView>
      </ListView.View>
    </ListView>
  </DockPanel>
</Window>

